rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDocExists() {
      return isSignedIn() && exists(userDocPath());
    }

    function roleFromDb() {
      return get(userDocPath()).data.role;
    }

    function staffConfigExists() {
      return exists(/databases/$(database)/documents/config/staff);
    }

    function staffConfig() {
      return get(/databases/$(database)/documents/config/staff).data;
    }

    function emailOnAdminList() {
      return isSignedIn()
        && request.auth.token.email != null
        && staffConfigExists()
        && request.auth.token.email in staffConfig().adminEmails;
    }

    function emailOnOperatorList() {
      return isSignedIn()
        && request.auth.token.email != null
        && staffConfigExists()
        && request.auth.token.email in staffConfig().operatorEmails;
    }

    // Claims (Admin SDK) OU doc users/ OU allowlist em config/staff (Spark, sem Functions).
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'admin' ||
        (userDocExists() && roleFromDb() == 'admin') ||
        emailOnAdminList()
      );
    }

    function isStaff() {
      return isSignedIn() && (
        request.auth.token.role in ['admin', 'operator'] ||
        (userDocExists() && roleFromDb() in ['admin', 'operator']) ||
        emailOnAdminList() ||
        emailOnOperatorList()
      );
    }

    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sites/{id}      { allow read; allow write: if isAdmin(); }
    match /partners/{id}   { allow read; allow write: if isAdmin(); }
    match /attractions/{id}{ allow read; allow write: if isStaff(); }
    match /ticketTypes/{id}{ allow read; allow write: if isStaff(); }
    match /products/{id}   { allow read; allow write: if isStaff(); }

    match /orders/{id} {
      allow read: if isStaff()
        || (isSignedIn() && resource.data.customerUid == request.auth.uid)
        || (isSignedIn()
            && request.auth.token.email != null
            && resource.data.customer.email == request.auth.token.email);
      allow create: if isSignedIn()
        && request.resource.data.customerUid == request.auth.uid;
      allow update, delete: if isStaff();
    }

    match /fulfillments/{id} {
      allow read: if isStaff()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/orders/$(resource.data.orderId))
            && (
              get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.customerUid
                == request.auth.uid
              || (
                request.auth.token.email != null
                && get(/databases/$(database)/documents/orders/$(resource.data.orderId)).data.customer.email
                  == request.auth.token.email
              )
            ));
      allow write: if isStaff();
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.role == 'customer';
      allow update: if isAdmin()
        || (isSignedIn()
            && request.auth.uid == uid
            && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }
  }
}
