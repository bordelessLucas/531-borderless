rules_version = '2';

/**
 * BOOTSTRAP TEMPORÁRIO — liberado só durante o seed inicial.
 * NÃO deixe publicado: o script de seed restaura firestore.rules ao terminar.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
