rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Bilhetes emitidos ficam sob tickets/{orderId}/... — só backoffice grava.
    match /tickets/{orderId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role in ['admin', 'operator'];
    }
    // Imagens do CMS: leitura pública, escrita para staff.
    match /cms/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.token.role in ['admin', 'operator'];
    }
  }
}
