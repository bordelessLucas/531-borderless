rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function staffConfigPath() {
      return /databases/(default)/documents/config/staff;
    }

    function isStaff() {
      return isSignedIn() && (
        request.auth.token.role in ['admin', 'operator']
        || (
          firestore.exists(userDocPath())
          && firestore.get(userDocPath()).data.role in ['admin', 'operator']
        )
        || (
          request.auth.token.email != null
          && firestore.exists(staffConfigPath())
          && (
            request.auth.token.email in firestore.get(staffConfigPath()).data.adminEmails
            || request.auth.token.email in firestore.get(staffConfigPath()).data.operatorEmails
          )
        )
      );
    }

    // Bilhetes emitidos — leitura autenticada; escrita só staff.
    match /tickets/{orderId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isStaff()
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/.*');
    }

    // Imagens do CMS: leitura pública, escrita para staff.
    match /cms/{allPaths=**} {
      allow read;
      allow write: if isStaff()
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
