# --- Firebase Web SDK (client) ---
# Preencha após criar o projeto: `npx -y firebase-tools@latest apps:sdkconfig WEB`
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Aponta o app para os emuladores locais (true em desenvolvimento).
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# --- Auth / papéis (sem Cloud Functions) ---
# E-mails separados por vírgula. No login, esses usuários entram como staff.
ADMIN_EMAILS=
OPERATOR_EMAILS=

# --- Firebase Admin SDK (server) ---
# Opcional no Spark. Com SA, dá para setCustomUserClaims.
FIREBASE_SERVICE_ACCOUNT=

# Domínio do site principal (fallback do resolvedor multi-tenant em dev).
NEXT_PUBLIC_DEFAULT_SITE=onerio
